POSTGRES_USER=...
POSTGRES_PASSWORD=...
POSTGRES_DB=...
PGBOUNCER_PORT=6432

# LLM / API keys
OPENAI_API_KEY=...
TAVILY_API_KEY=...

# Infrastructure (defaults to docker network aliases)
BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=rpc://
REDIS_URL=redis://redis:6379
DB_URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@pgbouncer:6432/${POSTGRES_DB}

# Future app Redis Sentinel migration
APP_REDIS_SENTINEL_MASTER=app-redis
APP_REDIS_SENTINEL_NODES=app-redis-sentinel-1:26379,app-redis-sentinel-2:26379,app-redis-sentinel-3:26379

# LANGSMITH_API_KEY=...
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=...

JWT_SECRET=...

# ClickHouse / Langfuse
CLICKHOUSE_URL=http://clickhouse-01:8123
CLICKHOUSE_MIGRATION_URL=clickhouse://clickhouse-01:9000
CLICKHOUSE_USER=...
CLICKHOUSE_PASSWORD=...
CLICKHOUSE_DB=...
CLICKHOUSE_CLUSTER_ENABLED=true

SONAR_TOKEN=...
